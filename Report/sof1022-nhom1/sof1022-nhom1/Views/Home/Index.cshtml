
@model IEnumerable<sof1022_nhom1.Models.Product>
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "TechItem";
}

<style>

    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family:Arial;
    }

    body{
        background:#020817;
        color:white;
    }


    .btn-login,
    .btn-register{
        padding:12px 25px;
        background:#007bff;
        border-radius:10px;
        color:white;
        margin-left:10px;
        transition:0.3s;
    }

    .btn-login:hover,
    .btn-register:hover{
        background:#1c93ff;
    }

    a{
        text-decoration:none;
        color:white;
    }

    /* HEADER */

    .header{
        width:100%;
        background:#031225;
        display:flex;
        justify-content:space-between;
        align-items:center;
        padding:20px 50px;
        border-bottom:1px solid #0f2b52;
    }

    .logo{
        display:flex;
        align-items:center;
        gap:10px;
    }

    .logo img{
        width:60px;
    }

    .logo-text{
        font-size:34px;
        font-weight:bold;
        color:#3da5ff;
    }

    .search-box{
        width:40%;
        position:relative;
    }

    .search-box input{
        width:100%;
        padding:15px 20px;
        border:none;
        border-radius:40px;
        background:#071a33;
        color:white;
        outline:none;
        font-size:16px;
    }

    .search-icon{
        position:absolute;
        right:20px;
        top:15px;
        font-size:20px;
    }

    .header-right{
        display:flex;
        gap:40px;
    }

    .header-item{
        text-align:center;
        cursor:pointer;
    }

    .header-item span{
        display:block;
        font-size:14px;
        color:#9db3cc;
        margin-top:5px;
    }

    /* MENU */

    .menu{
        width:100%;
        background:#04152c;
        padding:18px 50px;
        display:flex;
        gap:40px;
        align-items:center;
        border-bottom:1px solid #0c2b4d;
    }

    .menu a{
        transition:0.3s;
    }

    .menu a:hover{
        color:#3da5ff;
    }

    /* MAIN */

    .main{
        width:95%;
        margin:20px auto;
        display:flex;
        gap:20px;
    }

    /* SIDEBAR */

    .sidebar{
        width:20%;
        background:#04152c;
        border-radius:15px;
        padding:20px;
        height:fit-content;
        border:1px solid #0b2a4b;
    }

    .sidebar-title{
        font-size:22px;
        margin-bottom:20px;
        color:#3da5ff;
    }

    .category{
        padding:15px;
        border-radius:10px;
        margin-bottom:10px;
        background:#071c36;
        transition:0.3s;
        cursor:pointer;
    }

    .category:hover{
        background:#0b2a4b;
        transform:translateX(5px);
    }

    /* BANNER */

    .content{
        width:80%;
    }

    .banner{
        width:100%;
        height:420px;
        border-radius:20px;
        overflow:hidden;
        position:relative;
        background:url('https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=1974&auto=format&fit=crop') center;
        background-size:cover;
        border:1px solid #0b2a4b;
    }

    .banner-overlay{
        width:100%;
        height:100%;
        background:rgba(0,0,0,0.45);
        padding:60px;
    }

    .banner h1{
        font-size:60px;
        margin-bottom:20px;
        width:50%;
    }

    .banner p{
        font-size:22px;
        color:#8ebeff;
        margin-bottom:30px;
    }

    .banner button{
        padding:15px 40px;
        border:none;
        border-radius:40px;
        background:#007bff;
        color:white;
        font-size:18px;
        cursor:pointer;
        transition:0.3s;
    }

    .banner button:hover{
        background:#1c93ff;
        transform:scale(1.05);
    }

    /* FEATURES */

    .features{
        margin-top:20px;
        display:grid;
        grid-template-columns:repeat(4,1fr);
        gap:20px;
    }

    .feature-box{
        background:#04152c;
        padding:25px;
        border-radius:15px;
        border:1px solid #0b2a4b;
        text-align:center;
        transition:0.3s;
    }

    .feature-box:hover{
        transform:translateY(-5px);
    }

    .feature-box h3{
        margin-top:10px;
        margin-bottom:10px;
        color:#3da5ff;
    }

    .feature-box p{
        color:#9db3cc;
        font-size:14px;
    }

    /* CATEGORY CARD */

    .section-title{
        margin-top:40px;
        margin-bottom:20px;
        font-size:30px;
        color:#3da5ff;
    }

    .category-grid{
        display:grid;
        grid-template-columns:repeat(6,1fr);
        gap:20px;
    }

    .category-card{
        background:#04152c;
        padding:20px;
        border-radius:15px;
        text-align:center;
        border:1px solid #0b2a4b;
        transition:0.3s;
    }

    .category-card:hover{
        transform:translateY(-8px);
    }

    .category-card img{
        width:100%;
        height:120px;
        object-fit:cover;
        border-radius:10px;
        margin-bottom:15px;
    }

    /* PRODUCTS */

    .product-grid{
        display:grid;
        grid-template-columns:repeat(5,1fr);
        gap:20px;
        margin-top:20px;
    }

    .product-card{
        background:#04152c;
        border-radius:15px;
        padding:15px;
        border:1px solid #0b2a4b;
        transition:0.3s;
        position:relative;
    }

    .product-card:hover{
        transform:translateY(-8px);
    }

    .sale{
        position:absolute;
        top:10px;
        left:10px;
        background:red;
        padding:5px 10px;
        border-radius:8px;
        font-size:13px;
    }

    .product-card img{
        width:100%;
        height:180px;
        object-fit:cover;
        border-radius:10px;
    }

    .product-name{
        margin-top:15px;
        margin-bottom:10px;
        font-size:18px;
    }

    .price{
        color:#3da5ff;
        font-size:22px;
        font-weight:bold;
    }

    .old-price{
        text-decoration:line-through;
        color:gray;
        margin-top:5px;
    }

</style>

<div class="header">

    <div class="logo">
        <img src="~/image/logotech.jpg">
        
    </div>

    <div class="search-box">

        <input type="text"
               name="searchString"
               placeholder="Bạn cần tìm gì hôm nay?">

        <button type="submit"
                style="
            position:absolute;
            right:10px;
            top:8px;
            background:none;
            border:none;
            color:white;
            font-size:22px;">
            🔍
        </button>

    </div>

    <div class="header-right">


        @if (Context.Session.GetString("UserName") == null)
        {
            <a href="/Account/Login" class="btn-login">
                👤 Đăng nhập
            </a>

            <a href="/Account/Register" class="btn-register">
                👤 Đăng ký
            </a>
        }
        else
        {
            <div class="header-item">
                👤 @Context.Session.GetString("UserName")
            </div>

            <a href="/Account/Logout" class="btn-register">
                Đăng xuất
            </a>
        }


        <div class="header-item">
            ❤ 
            <span>Yêu thích</span>
        </div>

        <div class="header-item">
            🛒
            <span>Giỏ hàng</span>
        </div>

    </div>

</div>

<div class="menu">
    <a href="#">TRANG CHỦ</a>
    <a href="#">SẢN PHẨM</a>
    <a href="#">PC - LAPTOP</a>
    <a href="#">PHỤ KIỆN</a>
    <a href="#">TIN TỨC</a>
    <a href="#">KHUYẾN MÃI</a>
    <a href="#">LIÊN HỆ</a>
</div>

<div class="main">



    <div class="sidebar">

        <div class="sidebar-title">
            DANH MỤC
        </div>

        <div class="category">📱 Điện thoại</div>
        <div class="category">💻 Laptop</div>
        <div class="category">🖥 PC - Máy tính bàn</div>
        <div class="category">⌨ Gaming Gear</div>
        <div class="category">🎧 Tai nghe</div>
        <div class="category">📷 Camera</div>
        <div class="category">⌚ Smartwatch</div>
        <div class="category">🔊 Loa</div>

    </div>

  

    <div class="content">

    

        <div class="banner">

            <div class="banner-overlay">

                <h1>
                    CÔNG NGHỆ DẪN LỐI TƯƠNG LAI
                </h1>

                <p>
                    Đỉnh cao hiệu năng - Trải nghiệm đột phá
                </p>

                <button>
                    KHÁM PHÁ NGAY
                </button>

            </div>

        </div>

       

        <div class="features">

            <div class="feature-box">
                ✅
                <h3>Hàng chính hãng</h3>
                <p>100% sản phẩm chính hãng</p>
            </div>

            <div class="feature-box">
                🛡
                <h3>Bảo hành uy tín</h3>
                <p>Bảo hành 12 - 24 tháng</p>
            </div>

            <div class="feature-box">
                🚚
                <h3>Giao hàng toàn quốc</h3>
                <p>Giao nhanh 2h - 24h</p>
            </div>

            <div class="feature-box">
                ☎
                <h3>Hỗ trợ 24/7</h3>
                <p>Hotline: 1900 1234</p>
            </div>

        </div>


        <h2 class="section-title">
            DANH MỤC NỔI BẬT
        </h2>

        <div class="category-grid">

            <div class="category-card">
                <img src="https://images.unsplash.com/photo-1496181133206-80ce9b88a853?q=80&w=1974&auto=format&fit=crop">
                <h3>Laptop</h3>
            </div>

            <div class="category-card">
                <img src="https://images.unsplash.com/photo-1587202372775-e229f172b9d7?q=80&w=1974&auto=format&fit=crop">
                <h3>PC Gaming</h3>
            </div>

            <div class="category-card">
                <img src="https://images.unsplash.com/photo-1527443224154-c4a3942d3acf?q=80&w=1974&auto=format&fit=crop">
                <h3>Màn hình</h3>
            </div>

            <div class="category-card">
                <img src="https://images.unsplash.com/photo-1511467687858-23d96c32e4ae?q=80&w=1974&auto=format&fit=crop">
                <h3>Phụ kiện</h3>
            </div>

            <div class="category-card">
                <img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?q=80&w=1974&auto=format&fit=crop">
                <h3>Tai nghe</h3>
            </div>

            <div class="category-card">
                <img src="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?q=80&w=1974&auto=format&fit=crop">
                <h3>Điện thoại</h3>
            </div>

        </div>

        

        <h2 class="section-title">
            SẢN PHẨM NỔI BẬT
        </h2>

        <div class="product-grid">

            @foreach (var item in Model)
            {
                <div class="product-card">

                    <div class="sale">HOT</div>

                    <img src="@item.ImageUrl">

                    <div class="product-name">
                        @item.ProductName
                    </div>

                    <div class="price">
                        @item.Price.ToString("N0") đ
                    </div>

                    <div class="old-price">
                        Còn lại: @item.Quantity
                    </div>

                    <br />

                    <a href="/Products/Details/@item.ProductId"
                           style="
                        background:#007bff;
                        padding:10px 20px;
                        border-radius:10px;
                        display:inline-block;">
                        Xem chi tiết
                    </a>

                </div>
            }

        </div>

    </div>

</div>