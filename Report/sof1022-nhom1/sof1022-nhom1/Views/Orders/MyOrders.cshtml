@model IEnumerable<sof1022_nhom1.Models.Orders>

<style>

    body {
        background: #020817;
        color: white;
        font-family: Arial;
    }

    table {
        width: 90%;
        margin: 40px auto;
        border-collapse: collapse;
        background: #04152c;
    }

    th, td {
        padding: 20px;
        border: 1px solid #0b2a4b;
    }

    th {
        background: #0b2a4b;
    }

</style>

<h1 style="text-align:center;margin-top:30px;">
    Đơn hàng của tôi
</h1>

<table>

    <tr>

        <th>Mã đơn</th>

        <th>Ngày đặt</th>

        <th>Tổng tiền</th>

        <th>Trạng thái</th>

    </tr>

    @foreach (var item in Model)
    {
        <tr>

            <td>@item.OrderId</td>

            <td>@item.OrderDate</td>

            <td>@item.TotalMoney.ToString("N0") đ</td>

            <td>@item.Status</td>

        </tr>
    }

</table>